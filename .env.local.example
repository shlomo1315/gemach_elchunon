# העתק קובץ זה ל-.env.local (לפיתוח מקומי) והכנס את הערכים מ-Supabase
# ב-Vercel: הוסף את המשתנים האלה ב-Project Settings → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ===== התראות מייל (Resend) — אופציונלי =====
# בלי המשתנים האלה המערכת עובדת רגיל, פשוט לא נשלחים מיילים.
# 1) נרשמים בחינם ב-https://resend.com ויוצרים API Key.
# 2) ADMIN_EMAIL = המייל שלך (המנהל) שיקבל התראה על כל פעולה.
# 3) EMAIL_FROM = כתובת השולח. לבדיקות אפשר להשתמש ב-onboarding@resend.dev,
#    ולכתובת אמיתית צריך לאמת דומיין ב-Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=manager@example.com
EMAIL_FROM=גמ"ח זכרון אהרן <onboarding@resend.dev>
